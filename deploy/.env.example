# Mesa Digital — environment variables
# Copy this file to deploy/.env and fill in real values before deploying.
# Never commit deploy/.env to version control.

# Django / FastAPI secret key used for signing sessions and tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=

# SQLAlchemy connection string for the primary database.
# Format: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=

# Sentry DSN for error tracking. Leave empty to disable Sentry.
# Obtain from: https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=

# Comma-separated list of allowed CORS origins (no trailing slashes).
# Example: https://app.mesadigital.cl,https://admin.mesadigital.cl
CORS_ORIGINS=

# Email address for the first admin account created on initial deploy.
FIRST_ADMIN_EMAIL=

# Password for the first admin account. Must be changed after first login.
# Minimum 16 characters recommended.
FIRST_ADMIN_PASSWORD=
